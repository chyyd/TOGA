<Window x:Class="TreatmentHelper.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="治疗记录单生成器" Height="580" Width="500"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResizeWithGrip"
        FontFamily="Microsoft YaHei">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 标题 -->
        <TextBlock Grid.Row="0" Text="治疗记录单生成器" 
                   FontSize="18" FontWeight="Bold" 
                   HorizontalAlignment="Center" Margin="0,0,0,10"/>

        <!-- 分隔线 -->
        <Separator Grid.Row="1" Margin="0,0,0,10"/>

        <!-- 患者信息 -->
        <GroupBox Grid.Row="2" Header="患者信息" Padding="10,5">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="70"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0" Text="姓名：" 
                           VerticalAlignment="Center" HorizontalAlignment="Right"/>
                <TextBox Grid.Row="0" Grid.Column="1" x:Name="NameTextBox" 
                         Margin="5" MaxLength="20"
                         ToolTip="请输入患者姓名"/>

                <TextBlock Grid.Row="1" Grid.Column="0" Text="住院号：" 
                           VerticalAlignment="Center" HorizontalAlignment="Right"/>
                <TextBox Grid.Row="1" Grid.Column="1" x:Name="HospitalNoTextBox" 
                         Margin="5" MaxLength="20"
                         ToolTip="可选"/>

                <TextBlock Grid.Row="2" Grid.Column="0" Text="开始日期：" 
                           VerticalAlignment="Center" HorizontalAlignment="Right"/>
                <DatePicker Grid.Row="2" Grid.Column="1" x:Name="StartDatePicker" 
                            Margin="5" SelectedDateFormat="Short"/>
            </Grid>
        </GroupBox>

        <!-- 治疗信息 -->
        <GroupBox Grid.Row="3" Header="治疗信息" Padding="10,5" Margin="0,10,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="70"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0" Text="治疗项目：" 
                           VerticalAlignment="Center" HorizontalAlignment="Right"/>
                <ComboBox Grid.Row="0" Grid.Column="1" x:Name="TreatmentComboBox" 
                          Margin="5" SelectionChanged="TreatmentComboBox_SelectionChanged"/>

                <TextBlock Grid.Row="1" Grid.Column="0" Text="诊断：" 
                           VerticalAlignment="Center" HorizontalAlignment="Right"/>
                <ComboBox Grid.Row="1" Grid.Column="1" x:Name="DiagnosisComboBox" 
                          Margin="5" SelectionChanged="DiagnosisComboBox_SelectionChanged"/>

                <TextBlock Grid.Row="2" Grid.Column="0" Text="治疗内容：" 
                           VerticalAlignment="Top" HorizontalAlignment="Right" Margin="0,5,0,0"/>
                <TextBox Grid.Row="2" Grid.Column="1" x:Name="ContentTextBox" 
                         Margin="5" AcceptsReturn="True" TextWrapping="Wrap"
                         VerticalScrollBarVisibility="Auto"
                         MinHeight="100" ToolTip="选择治疗项目和诊断后自动填充，可编辑"/>
            </Grid>
        </GroupBox>

        <!-- 加收选项 -->
        <GroupBox Grid.Row="4" Header="加收选项（仅针灸）" Padding="10,5" Margin="0,10,0,0"
                  x:Name="SurchargeGroupBox">
            <StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,2">
                    <TextBlock Text="职称：" Width="65" 
                               VerticalAlignment="Center" HorizontalAlignment="Right"/>
                    <ComboBox x:Name="TitleComboBox" Width="150" Margin="5,0"
                              SelectionChanged="TitleComboBox_SelectionChanged"/>
                </StackPanel>
                <StackPanel x:Name="SurchargeItemsPanel" Orientation="Horizontal" Margin="0,5,0,0">
                    <TextBlock Text="加收项目：" Width="65" 
                               VerticalAlignment="Center" HorizontalAlignment="Right"/>
                    <StackPanel x:Name="ItemsCheckBoxPanel" Orientation="Horizontal"/>
                </StackPanel>
            </StackPanel>
        </GroupBox>

        <!-- 分隔线 -->
        <Separator Grid.Row="5" Margin="0,10,0,5"/>

        <!-- 按钮 -->
        <StackPanel Grid.Row="6" Orientation="Horizontal" HorizontalAlignment="Center">
            <Button Content="后台设置" Width="90" Height="28" Margin="0,0,20,0"
                    Click="SettingsButton_Click"/>
            <Button Content="预览" Width="90" Height="28" IsDefault="True"
                    Click="PreviewButton_Click"/>
        </StackPanel>
    </Grid>
</Window>
