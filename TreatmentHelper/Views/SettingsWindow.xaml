<Window x:Class="TreatmentHelper.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="后台设置" Height="550" Width="750"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResizeWithGrip"
        FontFamily="Microsoft YaHei">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 标题 -->
        <TextBlock Grid.Row="0" Text="后台设置" 
                   FontSize="16" FontWeight="Bold" 
                   HorizontalAlignment="Center" Margin="0,0,0,10"/>

        <!-- 医院名称 -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,10">
            <TextBlock Text="医院名称（可选）：" Width="120" VerticalAlignment="Center"/>
            <TextBox x:Name="HospitalNameTextBox" Width="300" MaxLength="50"
                     ToolTip="显示在治疗单顶部"/>
        </StackPanel>

        <!-- 分隔线 -->
        <Separator Grid.Row="2" Margin="0,0,0,10"/>

        <!-- 主内容区：左右分割 -->
        <Grid Grid.Row="3">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- 左侧：治疗项目管理 -->
            <GroupBox Grid.Column="0" Header="治疗项目" Padding="10">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <ListBox Grid.Row="0" x:Name="TreatmentListBox" 
                             SelectionChanged="TreatmentListBox_SelectionChanged"/>

                    <Grid Grid.Row="1" Margin="0,5">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="50"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="名称：" 
                                   VerticalAlignment="Center" HorizontalAlignment="Right"/>
                        <TextBox Grid.Column="1" x:Name="TreatmentNameTextBox" Margin="5,0"/>
                    </Grid>

                    <Grid Grid.Row="2" Margin="0,5">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="50"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="时长：" 
                                   VerticalAlignment="Center" HorizontalAlignment="Right"/>
                        <TextBox Grid.Column="1" x:Name="TreatmentDurationTextBox" 
                                 Margin="5,0" ToolTip="如：30分钟"/>
                    </Grid>

                    <StackPanel Grid.Row="3" Orientation="Horizontal" Margin="0,5">
                        <Button Content="添加" Width="60" Margin="0,0,10,0" 
                                Click="AddTreatmentButton_Click"/>
                        <Button Content="更新" Width="60" Margin="0,0,10,0" 
                                Click="UpdateTreatmentButton_Click"/>
                        <Button Content="删除" Width="60" Click="DeleteTreatmentButton_Click"/>
                    </StackPanel>
                </Grid>
            </GroupBox>

            <GridSplitter Grid.Column="1" Width="5" HorizontalAlignment="Center" 
                          VerticalAlignment="Stretch" Background="Transparent"/>

            <!-- 右侧：诊断管理 -->
            <GroupBox Grid.Column="2" Header="诊断及治疗内容" Padding="10">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="请先在左侧选择一个治疗项目" 
                               Foreground="Gray" Margin="0,0,0,5"/>

                    <ListBox Grid.Row="1" x:Name="DiagnosisListBox" 
                             SelectionChanged="DiagnosisListBox_SelectionChanged"/>

                    <Grid Grid.Row="2" Margin="0,5">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="50"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="诊断：" 
                                   VerticalAlignment="Center" HorizontalAlignment="Right"/>
                        <TextBox Grid.Column="1" x:Name="DiagnosisNameTextBox" Margin="5,0"/>
                    </Grid>

                    <Grid Grid.Row="3" Margin="0,5">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Text="治疗内容："/>
                        <TextBox Grid.Row="1" x:Name="DetailsTextBox" 
                                 AcceptsReturn="True" TextWrapping="Wrap"
                                 VerticalScrollBarVisibility="Auto"
                                 Margin="0,5"/>
                    </Grid>

                    <StackPanel Grid.Row="4" Orientation="Horizontal" Margin="0,5">
                        <Button Content="添加" Width="60" Margin="0,0,10,0" 
                                Click="AddDiagnosisButton_Click"/>
                        <Button Content="更新" Width="60" Margin="0,0,10,0" 
                                Click="UpdateDiagnosisButton_Click"/>
                        <Button Content="删除" Width="60" Click="DeleteDiagnosisButton_Click"/>
                    </StackPanel>
                </Grid>
            </GroupBox>
        </Grid>

        <!-- 底部按钮 -->
        <StackPanel Grid.Row="4" Orientation="Horizontal" 
                    HorizontalAlignment="Center" Margin="0,15,0,0">
            <Button Content="保存" Width="90" Height="28" Margin="0,0,15,0"
                    Click="SaveButton_Click" IsDefault="True"/>
            <Button Content="取消" Width="90" Height="28" Click="CancelButton_Click"/>
        </StackPanel>
    </Grid>
</Window>
